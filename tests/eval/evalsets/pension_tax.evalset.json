    {
      "eval_id": "pension_payout_simulation",
      "conversation": [
        {
          "invocation_id": "inv_1",
          "user_content": { "parts": [{"text": "IRP에 8000만 원 쌓였는데 만 60세부터 10년간 받으면 한 달에 얼마예요?"}] },
          "intermediate_data": {
